EPUB_CHAPTERS_API_DATA_DIR=.local_api_data
EPUB_CHAPTERS_FRONTEND_DIST=dist
EPUB_CHAPTERS_HOST=127.0.0.1
EPUB_CHAPTERS_PORT=4321
VITE_API_BASE_URL=
# Comma-separated browser origins allowed to call the API (CORS allow-list).
# Defaults to the localhost UI origins; never use "*".
EPUB_CHAPTERS_API_CORS_ORIGINS=http://127.0.0.1:4322,http://localhost:4322

# Optional local model/cache locations. Keep these inside the project workspace
# or another trusted local path you control; never commit downloaded model data.
CHATTERBOX_MODEL_PATH=
HF_HOME=.local_model_cache/huggingface
TORCH_HOME=.local_model_cache/torch
